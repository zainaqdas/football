---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title = 'Gol HD — Fútbol en Vivo y Canales Deportivos HD', description = 'Disfruta de fútbol en vivo y canales deportivos HD en Gol HD. Mira partidos de fútbol online, programación deportiva y streaming de deportes en vivo desde cualquier lugar. Accede a los mejores canales de deportes gratis.' } = Astro.props;

const rawCanonical = Astro.props.canonical || '/';
const siteOrigin = Astro.url.origin;
// If canonical is a relative path (starts with /), prepend the origin
const canonical = rawCanonical.startsWith('/') ? siteOrigin + rawCanonical : rawCanonical;

// JSON-LD schema strings (built dynamically so no hardcoded domain)
const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Gol HD',
  url: siteOrigin,
  logo: siteOrigin + '/logo.svg',
  description: 'Gol HD es tu plataforma de streaming de deportes en vivo. Disfruta de canales deportivos y partidos de fútbol en HD desde cualquier lugar.',
  sameAs: [],
});

const siteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Gol HD',
  url: siteOrigin,
  description: 'Canales deportivos en vivo y partidos de fútbol en HD. Mira fútbol en vivo, sigue la programación deportiva y disfruta de streaming deportivo gratis.',
  inLanguage: 'es',
  potentialAction: {
    '@type': 'SearchAction',
    target: siteOrigin + '/channels?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="theme-color" content="#09090b" />
    <meta name="keywords" content="fútbol en vivo, canales deportivos en vivo, ver fútbol gratis, partidos en vivo hoy, streaming deportes HD, canales HD en vivo, deportes en vivo gratis, fútbol online, liga española en vivo, premier league en vivo" />
    <meta name="author" content="Gol HD" />
    <link rel="canonical" href={canonical} />

    <!-- JSON-LD Schema: Organization -->
    <script type="application/ld+json">{orgSchema}</script>

    <!-- JSON-LD Schema: WebSite -->
    <script type="application/ld+json">{siteSchema}</script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Gol HD" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossOrigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossOrigin />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-canvas-soft text-ink antialiased">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 h-16 bg-canvas/80 backdrop-blur-md border-b border-hairline" style="background: rgba(24, 24, 27, 0.85);">
      <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-2 no-underline group">
          <img src="/logo.svg" alt="Gol HD" class="h-9 w-auto" />
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          <a href="/" class="nav-link">Home</a>
          <a href="/channels" class="nav-link">Channels</a>
          <a href="/events" class="nav-link">Events</a>
        </div>

        <!-- Desktop right side -->
        <div class="hidden md:flex items-center gap-2">
          <a href="/channels" class="btn-primary" style="height: 2rem; padding: 0 1rem; font-size: 0.8125rem;">
            Watch Live
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="md:hidden flex items-center justify-center w-9 h-9 rounded-full border border-hairline bg-canvas text-ink cursor-pointer hover:bg-white/10 transition-colors" aria-label="Toggle menu" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-40 hidden bg-canvas-soft/98 backdrop-blur-lg">
      <div class="flex flex-col items-center justify-center h-full gap-8">
        <a href="/" class="text-2xl font-semibold no-underline text-white hover:text-body transition-colors" onclick="closeMenu()">Home</a>
        <a href="/channels" class="text-2xl font-semibold no-underline text-white hover:text-body transition-colors" onclick="closeMenu()">Channels</a>
        <a href="/events" class="text-2xl font-semibold no-underline text-white hover:text-body transition-colors" onclick="closeMenu()">Events</a>
        <a href="/channels" class="btn-primary mt-4" style="height: 2.5rem; padding: 0 1.5rem;" onclick="closeMenu()">
          Watch Live
        </a>
        <button id="menu-close" class="mt-8 text-sm text-mute hover:text-body transition-colors cursor-pointer bg-transparent border-none" onclick="closeMenu()">Close</button>
      </div>
    </div>

    <!-- Main content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-hairline" style="background: #0d0d10;">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <h4 class="text-xs font-mono text-mute uppercase tracking-wider mb-4" style="color: #52525b;">Navigation</h4>
            <ul class="space-y-3">
              <li><a href="/" class="text-sm text-body no-underline hover:text-white transition-colors">Home</a></li>
              <li><a href="/channels" class="text-sm text-body no-underline hover:text-white transition-colors">Channels</a></li>
              <li><a href="/events" class="text-sm text-body no-underline hover:text-white transition-colors">Events</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-mono text-mute uppercase tracking-wider mb-4" style="color: #52525b;">Channels</h4>
            <ul class="space-y-3">
              <li><a href="/channels/argentina" class="text-sm text-body no-underline hover:text-white transition-colors">Argentina</a></li>
              <li><a href="/channels/mexico" class="text-sm text-body no-underline hover:text-white transition-colors">Mexico</a></li>
              <li><a href="/channels/espana" class="text-sm text-body no-underline hover:text-white transition-colors">Spain</a></li>
              <li><a href="/channels/usa" class="text-sm text-body no-underline hover:text-white transition-colors">USA</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-mono text-mute uppercase tracking-wider mb-4" style="color: #52525b;">Regions</h4>
            <ul class="space-y-3">
              <li><a href="/channels/latinoamerica" class="text-sm text-body no-underline hover:text-white transition-colors">Latin America</a></li>
              <li><a href="/channels/brasil" class="text-sm text-body no-underline hover:text-white transition-colors">Brazil</a></li>
              <li><a href="/channels/portugal" class="text-sm text-body no-underline hover:text-white transition-colors">Portugal</a></li>
              <li><a href="/channels/mundo" class="text-sm text-body no-underline hover:text-white transition-colors">World</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-mono text-mute uppercase tracking-wider mb-4" style="color: #52525b;">Info</h4>
            <ul class="space-y-3">
              <li><span class="text-sm font-semibold text-ink">Gol HD</span></li>
              <li><span class="text-sm text-body">Live sports channels & matches</span></li>
              <li><span class="text-sm text-body">HD quality streaming</span></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-mute" style="color: #52525b;">&copy; {new Date().getFullYear()} Gol HD. All rights reserved.</p>
          <p class="text-xs font-mono" style="color: #3f3f46;">Gol HD</p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuToggle = document.getElementById('menu-toggle');
      const menuClose = document.getElementById('menu-close');
      const mobileMenu = document.getElementById('mobile-menu');

      if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', function() {
          mobileMenu.style.display = 'flex';
          document.body.style.overflow = 'hidden';
          menuToggle.setAttribute('aria-expanded', 'true');
        });
      }

      window.closeMenu = function() {
        if (mobileMenu) {
          mobileMenu.style.display = 'none';
          document.body.style.overflow = '';
          if (menuToggle) {
            menuToggle.setAttribute('aria-expanded', 'false');
          }
        }
      };

      if (menuClose) {
        menuClose.addEventListener('click', function() {
          window.closeMenu();
        });
      }

      // Close menu on resize to desktop
      window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) {
          window.closeMenu();
        }
      });
    </script>
  </body>
</html>

<style is:global>
  .nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--color-body);
    text-decoration: none;
    border-radius: 9999px;
    transition: color 0.15s, background-color 0.15s;
  }
  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft-2);
  }
</style>
