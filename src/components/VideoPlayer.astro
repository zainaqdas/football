---
export interface Props {
  streamId?: string;
  channelName?: string;
  class?: string;
}

const { streamId, channelName = 'Stream', class: className = '' } = Astro.props;
const iframeUrl = streamId
  ? `https://tvtvhd.com/vivo/canales.php?stream=${encodeURIComponent(streamId)}`
  : null;
---

<div class={`relative bg-black rounded-xl overflow-hidden ${className}`}>
  {iframeUrl ? (
    <iframe
      src={iframeUrl}
      class="w-full aspect-video"
      allowfullscreen
      allow="autoplay; encrypted-media; picture-in-picture"
      referrerpolicy="no-referrer-when-downgrade"
      loading="eager"
      style="border: 0;"
    />
  ) : (
    <div class="w-full aspect-video bg-ink flex items-center justify-center">
      <div class="text-center px-4">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/10 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </div>
        <p class="text-white/60 text-sm">Stream no disponible</p>
        <p class="text-white/40 text-xs mt-1">No hay una fuente disponible para este canal.</p>
      </div>
    </div>
  )}
</div>
