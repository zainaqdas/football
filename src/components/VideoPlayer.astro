---
export interface Props {
  hlsUrl?: string;
  channelName?: string;
  class?: string;
}

const { hlsUrl, channelName = 'Stream', class: className = '' } = Astro.props;
const playerId = `player-${Math.random().toString(36).slice(2, 8)}`;
---

<div class={`relative bg-black rounded-xl overflow-hidden ${className}`}>
  {hlsUrl ? (
    <>
      <video
        id={playerId}
        class="w-full aspect-video"
        controls
        playsinline
        preload="metadata"
      >
        <p>Tu navegador no soporta la reproducción de video.</p>
      </video>

      <script define:vars={{ hlsUrl, playerId }}>
        import Hls from 'hls.js';

        (function() {
          try {
            const video = document.getElementById(playerId);
            if (!video) return;

            if (Hls.isSupported()) {
              const hls = new Hls({
                enableWorker: false,
                lowLatencyMode: true,
                backbufferLength: 30,
              });
              hls.loadSource(hlsUrl);
              hls.attachMedia(video);
              hls.on(Hls.Events.MANIFEST_PARSED, function() {
                video.play().catch(function() {
                  // Autoplay blocked — user will click play
                });
              });
              hls.on(Hls.Events.ERROR, function(event, data) {
                if (data.fatal) {
                  switch(data.type) {
                    case Hls.ErrorTypes.NETWORK_ERROR:
                      hls.startLoad();
                      break;
                    case Hls.ErrorTypes.MEDIA_ERROR:
                      hls.recoverMediaError();
                      break;
                    default:
                      console.error('HLS fatal error:', data);
                      break;
                  }
                }
              });

              // Cleanup on navigation away
              window.addEventListener('beforeunload', function() {
                hls.destroy();
              });
              window.addEventListener('pagehide', function() {
                hls.destroy();
              });
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
              video.src = hlsUrl;
              video.addEventListener('loadedmetadata', function() {
                video.play().catch(function() {});
              });
            } else {
              video.insertAdjacentHTML('afterend',
                '<div class="absolute inset-0 flex items-center justify-center bg-ink/90"><p class="text-white/60 text-sm px-4 text-center">Este navegador no soporta HLS.</p></div>'
              );
            }
          } catch (e) {
            console.error('Error loading HLS player:', e);
          }
        })();
      </script>
    </>
  ) : (
    <div class="w-full aspect-video bg-ink flex items-center justify-center">
      <div class="text-center px-4">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/10 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </div>
        <p class="text-white/60 text-sm">Stream no disponible</p>
        <p class="text-white/40 text-xs mt-1">No hay una fuente de video disponible para este canal.</p>
      </div>
    </div>
  )}
</div>
