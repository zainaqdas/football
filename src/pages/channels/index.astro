---
import Layout from '../../layouts/Layout.astro';
import ChannelCard from '../../components/ChannelCard.astro';
import NavTabs from '../../components/NavTabs.astro';
import SearchBar from '../../components/SearchBar.astro';
import { TVTVHDScraper } from '../../../scraper/src/index.js';
import { withCache } from '../../lib/cache.ts';

const scraper = new TVTVHDScraper();

const CACHE_TTL = 30_000; // 30 seconds

const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('q') || '';
const activeCategory = url.searchParams.get('category') || '';

let allChannels, categories, channelStats;
try {
  [allChannels, categories, channelStats] = await Promise.all([
    withCache('channels.all', CACHE_TTL, () => scraper.getAllChannels()),
    withCache('channels.categories', CACHE_TTL, () => scraper.getCategories()),
    withCache('channels.stats', CACHE_TTL, () => scraper.getChannelStats()),
  ]);
} catch (e) {
  allChannels = [];
  categories = [];
  channelStats = { totalActive: 0 };
}

// Filter by search
let filtered = allChannels;
if (searchQuery) {
  const q = searchQuery.toLowerCase();
  filtered = filtered.filter(ch =>
    ch.name.toLowerCase().includes(q) ||
    ch.category.toLowerCase().includes(q)
  );
}

// Filter by tab
const showActive = activeCategory === 'active';
if (showActive) {
  filtered = filtered.filter(ch => ch.isActive);
} else if (activeCategory) {
  const normalized = activeCategory.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
  filtered = filtered.filter(ch =>
    ch.category.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase() === normalized
  );
}

// Sort: active first, then alphabetically
filtered.sort((a, b) => {
  if (a.isActive !== b.isActive) return a.isActive ? -1 : 1;
  return a.name.localeCompare(b.name);
});

const tabItems = [
  { label: 'All', href: '/channels', active: !activeCategory && !searchQuery, count: allChannels.length },
  { label: 'Live', href: '/channels?category=active', active: showActive, count: channelStats.totalActive },
  ...categories.map(c => ({
    label: c,
    href: `/channels?category=${c.toLowerCase()}`,
    active: activeCategory.toLowerCase() === c.toLowerCase(),
  })),
];
---

<Layout title="Canales Deportivos en Vivo HD — Gol HD" description="Explora todos los canales deportivos en vivo HD en Gol HD. Filtra por región, busca tu canal favorito y disfruta de fútbol en vivo y streaming de deportes gratis. Canales de deportes en HD." canonical="/channels">
  
  <section class="bg-canvas border-b border-hairline">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div>
          <p class="text-xs font-mono text-mute uppercase tracking-widest mb-2">Channels</p>
          <h1 class="text-3xl sm:text-4xl font-semibold text-ink tracking-[-1.28px]">
            {searchQuery ? `"${searchQuery}"` : activeCategory ? activeCategory.charAt(0).toUpperCase() + activeCategory.slice(1) : 'All channels'}
          </h1>
          <p class="mt-1 text-sm text-body">
            {filtered.length} channel{filtered.length !== 1 ? 's' : ''}
            {searchQuery ? ` found for "${searchQuery}"` : ''}
          </p>
        </div>
        <div class="w-full sm:w-72">
          <SearchBar placeholder="Search channels..." value={searchQuery} action="/channels" method="GET" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-canvas-soft py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="overflow-x-auto pb-2 -mb-2">
        <NavTabs items={tabItems} class="flex-nowrap sm:flex-wrap" />
      </div>
    </div>
  </section>

  <section class="bg-canvas-soft pb-16 sm:pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {filtered.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 stagger-children">
          {filtered.map((ch, i) => (
            <ChannelCard
              name={ch.name}
              category={ch.category}
              streamUrl={ch.streamUrl}
              isActive={ch.isActive}
              index={i}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-canvas-soft-2 flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-mute">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-ink mb-2">
            {searchQuery ? `No channels found for "${searchQuery}"` : 'No channels in this category'}
          </h3>
          <p class="text-sm text-mute mb-6">Try a different search term or browse all categories.</p>
          <a href="/channels" class="btn-primary" style="height: 2.5rem; padding: 0 1.5rem; font-size: 0.875rem;">
            View all channels
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>
