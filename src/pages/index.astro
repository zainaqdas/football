---
import Layout from '../layouts/Layout.astro';
import StatsCard from '../components/StatsCard.astro';
import ChannelCard from '../components/ChannelCard.astro';
import EventCard from '../components/EventCard.astro';
import { TVTVHDScraper } from '../../scraper/src/index.js';

const scraper = new TVTVHDScraper();

import { withCache } from '../lib/cache.ts';

const CHANNELS_TTL = 30_000; // 30 seconds
const EVENTS_TTL = 60_000;   // 60 seconds

let channelStats, categories, allChannels, todayEvents, activeChannels, eventStats;
try {
  [allChannels, categories, channelStats] = await Promise.all([
    withCache('channels.all', CHANNELS_TTL, () => scraper.getAllChannels()),
    withCache('channels.categories', CHANNELS_TTL, () => scraper.getCategories()),
    withCache('channels.stats', CHANNELS_TTL, () => scraper.getChannelStats()),
  ]);
  [todayEvents, eventStats] = await Promise.all([
    withCache('events.today', EVENTS_TTL, () => scraper.getTodaysEvents()),
    withCache('events.stats', EVENTS_TTL, () => scraper.getEventStats()),
  ]);
} catch (e) {
  channelStats = { totalChannels: 0, totalActive: 0, totalInactive: 0, totalCategories: 0, categories: [] };
  categories = [];
  allChannels = [];
  todayEvents = [];
  eventStats = { totalEvents: 0, uniqueCountries: [] };
}

// Get active channels for featured grid
const featuredChannels = allChannels.filter(c => c.isActive).slice(0, 8);
---

<Layout title="Gol HD — Fútbol en Vivo y Canales Deportivos HD | Ver Partidos Online" description="Disfruta de fútbol en vivo y canales deportivos HD en Gol HD. Mira partidos de fútbol online, programación deportiva y streaming de deportes en vivo. Accede a los mejores canales de deportes gratis desde cualquier lugar." canonical="https://golhd.tv/">
  
  <!-- ═══ HERO BAND ═══ -->
  <section class="relative overflow-hidden bg-canvas">
    <div class="mesh-gradient absolute inset-0 opacity-60" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-canvas/80 backdrop-blur-sm border border-hairline rounded-full text-xs font-mono text-body mb-8 animate-fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse" />
          {channelStats.totalActive} live HD channels
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-semibold text-ink leading-[1.05] tracking-[-2.8px] sm:tracking-[-3.6px] animate-fade-in" style="animation-delay: 100ms">
          Live football<br />
          <span class="bg-gradient-to-r from-grad-dev-start via-grad-prev-end to-grad-ship-start bg-clip-text text-transparent">in HD, wherever you are.</span>
        </h1>

        <p class="mt-8 text-xl sm:text-2xl text-body leading-relaxed max-w-2xl mx-auto animate-fade-in" style="animation-delay: 200ms">
          Gol HD brings you live sports channels and match schedules from the world's most important leagues and tournaments — all in one place, in HD quality.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in" style="animation-delay: 300ms">
          <a href="/channels" class="btn-primary" style="height: 3rem; padding: 0 2rem; font-size: 1rem;">
            Explore Channels
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a href="/events" class="btn-secondary" style="height: 3rem; padding: 0 2rem; font-size: 1rem;">
            View Schedule
          </a>
        </div>
      </div>
    </div>
    <!-- Gradient fade at bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-canvas-soft to-transparent" />
  </section>

  <!-- ═══ STATS BAND ═══ -->
  <section class="bg-canvas-soft py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 stagger-children">
        <StatsCard label="Total Channels" value={channelStats.totalChannels} icon="channels" />
        <StatsCard label="Live Channels" value={channelStats.totalActive} change={`${Math.round(channelStats.totalActive / channelStats.totalChannels * 100)}%`} icon="active" />
        <StatsCard label="Categories" value={channelStats.totalCategories} icon="categories" />
        <StatsCard label="Events Today" value={eventStats.totalEvents} change={`${eventStats.uniqueCountries.length} countries`} icon="events" />
      </div>
    </div>
  </section>

  <!-- ═══ CATEGORIES BAND ═══ -->
  <section class="bg-canvas py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-mono text-mute uppercase tracking-widest mb-3">Categories</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-ink tracking-[-1.28px]">
          Explore by region.
        </h2>
        <p class="mt-3 text-body text-base max-w-lg mx-auto">
          {channelStats.totalCategories} regions with live sports channels.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 stagger-children">
        {channelStats.categories.map((cat) => (
          <a
            href={`/channels/${cat.name.toLowerCase()}`}
            class="group bg-canvas rounded-lg card-hairline p-5 text-center no-underline transition-all duration-300 hover:shadow-elevated hover:-translate-y-0.5"
          >
            <div class="w-10 h-10 mx-auto mb-3 rounded-lg bg-canvas-soft-2 flex items-center justify-center group-hover:bg-ink group-hover:text-white transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-ink group-hover:text-link transition-colors">{cat.name}</h3>
            <p class="text-xs text-mute mt-1 font-mono">
              {cat.active}/{cat.total} active
            </p>
            <!-- Mini bar -->
            <div class="mt-3 h-1 bg-canvas-soft-2 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full transition-all duration-500" style={`width: ${cat.total > 0 ? (cat.active / cat.total * 100) : 0}%`} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED CHANNELS BAND ═══ -->
  <section class="bg-canvas-soft py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-mono text-mute uppercase tracking-widest mb-3">Live Now</p>
          <h2 class="text-3xl sm:text-4xl font-semibold text-ink tracking-[-1.28px]">
            Featured channels.
          </h2>
        </div>
        <a href="/channels" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-link no-underline hover:underline">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      {featuredChannels.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 stagger-children">
          {featuredChannels.map((ch, i) => (
            <ChannelCard
              name={ch.name}
              category={ch.category}
              streamUrl={ch.streamUrl}
              isActive={ch.isActive}
              index={i}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-mute">
          <p>No channels available at the moment.</p>
        </div>
      )}

      <div class="mt-8 text-center sm:hidden">
        <a href="/channels" class="btn-primary" style="height: 2.5rem; padding: 0 1.5rem; font-size: 0.875rem;">
          View all channels
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ TODAY'S EVENTS BAND ═══ -->
  <section class="bg-canvas py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-mono text-mute uppercase tracking-widest mb-3">Sports Schedule</p>
          <h2 class="text-3xl sm:text-4xl font-semibold text-ink tracking-[-1.28px]">
            Today's matches.
          </h2>
          <p class="mt-2 text-body text-sm">{todayEvents.length} event{todayEvents.length !== 1 ? 's' : ''} scheduled</p>
        </div>
        <a href="/events" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-link no-underline hover:underline">
          View full schedule
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      {todayEvents.length > 0 ? (
        <div class="space-y-3 stagger-children">
          {todayEvents.slice(0, 8).map((ev, i) => (
            <EventCard
              description={ev.description}
              hour={ev.hour}
              date={ev.date}
              country={ev.country}
              embeds={ev.embeds}
              index={i}
            />
          ))}
          {todayEvents.length > 8 && (
            <div class="text-center pt-6">
              <a href="/events" class="inline-flex items-center gap-1.5 text-sm font-medium text-link no-underline hover:underline">
                View all {todayEvents.length} event{todayEvents.length !== 1 ? 's' : ''} today
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          )}
        </div>
      ) : (
        <div class="text-center py-16 text-mute">
          <p>No events scheduled for today.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ CTA BAND ═══ -->
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(135deg, #0f0f13 0%, #1a1a2e 50%, #0f0f13 100%)">
    <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse 60% 50% at 50% 80%, rgba(59,130,246,0.3) 0%, transparent 60%)" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-semibold text-ink tracking-[-1.28px]">
        All football in one place.
      </h2>
      <p class="mt-4 text-lg text-body max-w-lg mx-auto">
        {channelStats.totalChannels} channels from {channelStats.totalCategories} regions. Live streams of the most important leagues and tournaments.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/channels" class="btn-primary" style="height: 3rem; padding: 0 2rem; font-size: 1rem;">
          Start Watching
        </a>
        <a href="/events" class="btn-secondary" style="height: 3rem; padding: 0 2rem; font-size: 1rem;">
          View Schedule
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SEO CONTENT BAND ═══ -->
  <section class="bg-canvas-soft py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        
        <h2 class="text-2xl sm:text-3xl font-semibold text-ink mb-8 text-center">
          Fútbol en Vivo y Canales Deportivos HD — Todo en un Solo Lugar
        </h2>

        <div class="text-body text-base leading-relaxed space-y-5">
          <p>
            Bienvenido a <strong>Gol HD</strong>, tu plataforma definitiva para disfrutar de <a href="/channels" class="text-link underline hover:no-underline">fútbol en vivo</a> y canales deportivos HD desde cualquier lugar del mundo. Aquí encontrarás todo lo que necesitas para seguir los partidos de fútbol online, con la mejor calidad de streaming y sin complicaciones. Ya seas fanático de la Liga Española, la Premier League, la Serie A, la Bundesliga o la Liga MX, Gol HD te ofrece acceso directo a los mejores canales de deportes gratis.
          </p>

          <p>
            Nuestro objetivo es simple: que puedas <strong>ver fútbol gratis</strong> y en vivo, sin tener que buscar enlaces perdidos por toda la web. Reunimos en un solo lugar los canales de televisión deportiva más importantes del mundo, organizados por región y categoría. Desde Argentina y México hasta España, Brasil y Estados Unidos, cubrimos las ligas y torneos más seguidos del planeta. Si quieres <strong>ver partidos en vivo hoy</strong>, solo tienes que entrar a nuestra sección de canales y elegir el que más te guste.
          </p>

          <h3 class="text-xl font-semibold text-ink mt-8 mb-4">
            Canales Deportivos en Vivo para Todas las Ligas
          </h3>

          <p>
            En Gol HD contamos con una amplia selección de <strong>canales deportivos en vivo</strong> que transmiten las competiciones más importantes del fútbol mundial. Puedes seguir la Liga Profesional Argentina, el Campeonato Brasileño, la Liga BetPlay de Colombia, la Liga 1 de Perú, el Campeonato Nacional de Chile y muchas más. Además, cubrimos torneos internacionales como la <strong>Copa Libertadores</strong>, la Copa Sudamericana, la Champions League, la Europa League y los partidos de las selecciones nacionales en eliminatorias mundialistas.
          </p>

          <p>
            No solo nos enfocamos en fútbol. También encontrarás canales de deportes como béisbol, básquetbol, tenis, Fórmula 1, boxeo y más. Todo en un solo sitio, con <strong>streaming de deportes en vivo HD</strong> para que no te pierdas ni un segundo de la acción. Navega por nuestras categorías, busca tu canal favorito y comienza a disfrutar del mejor contenido deportivo en línea.
          </p>

          <h3 class="text-xl font-semibold text-ink mt-8 mb-4">
            Programación Deportiva y Horarios de Partidos
          </h3>

          <p>
            ¿No sabes a qué hora juega tu equipo favorito? No te preocupes. En nuestra sección de <a href="/events" class="text-link underline hover:no-underline">programación deportiva</a> encontrarás los horarios de partidos actualizados día a día. Organizamos los eventos por fecha y país, para que puedas planificar tu agenda deportiva sin esfuerzo. Saber qué partidos hay hoy, a qué hora empiezan y en qué canal se transmiten es tan fácil como visitar nuestra página de eventos.
          </p>

          <p>
            La programación incluye desde los torneos más importantes hasta ligas locales y amistosos internacionales. Ya sea que quieras ver la Liga Española en vivo, seguir la Premier League, o disfrutar del fútbol mexicano, aquí encontrarás la <strong>guía completa de partidos de fútbol online</strong>. Nunca más te perderás un partido importante gracias a nuestra programación actualizada en tiempo real.
          </p>

          <h3 class="text-xl font-semibold text-ink mt-8 mb-4">
            Streaming Deportivo en HD desde Cualquier Dispositivo
          </h3>

          <p>
            Una de las mejores ventajas de Gol HD es que puedes acceder a nuestros <strong>canales HD en vivo</strong> desde cualquier dispositivo con conexión a internet. Funciona perfectamente en computadoras, tablets, teléfonos inteligentes y smart TVs. No necesitas descargar ninguna aplicación ni registrarte — solo abres el navegador y empiezas a ver deportes en vivo gratis al instante.
          </p>

          <p>
            La calidad de <strong>streaming deportes en vivo HD</strong> está optimizada para que disfrutes de una experiencia fluida, con la mejor resolución posible. Ya no tendrás que lidiar con enlaces rotos, páginas llenas de publicidad molesta o reproductores que no funcionan. Gol HD te ofrece una experiencia limpia, rápida y directa al mejor contenido deportivo del mundo.
          </p>

          <p>
            Si eres un verdadero apasionado del deporte, sabes lo importante que es tener acceso rápido y confiable a los partidos. Por eso creamos Gol HD: para que puedas <strong>ver fútbol en vivo</strong> y seguir a tus equipos favoritos sin barreras. Explora nuestros canales, revisa la programación y prepárate para vivir la emoción del deporte en HD, donde quiera que estés.
          </p>

          <p class="text-center pt-6">
            <a href="/channels" class="btn-primary">
              Comienza a Ver Fútbol en Vivo Ahora
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
