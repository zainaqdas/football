---
import Layout from '../layouts/Layout.astro';
import StatsCard from '../components/StatsCard.astro';
import ChannelCard from '../components/ChannelCard.astro';
import EventCard from '../components/EventCard.astro';
import { TVTVHDScraper } from '../../scraper/src/index.js';

const scraper = new TVTVHDScraper();

import { withCache } from '../lib/cache.ts';

const CHANNELS_TTL = 30_000; // 30 seconds
const EVENTS_TTL = 60_000;   // 60 seconds

let channelStats, categories, allChannels, todayEvents, activeChannels, eventStats;
try {
  [allChannels, categories, channelStats] = await Promise.all([
    withCache('channels.all', CHANNELS_TTL, () => scraper.getAllChannels()),
    withCache('channels.categories', CHANNELS_TTL, () => scraper.getCategories()),
    withCache('channels.stats', CHANNELS_TTL, () => scraper.getChannelStats()),
  ]);
  [todayEvents, eventStats] = await Promise.all([
    withCache('events.today', EVENTS_TTL, () => scraper.getTodaysEvents()),
    withCache('events.stats', EVENTS_TTL, () => scraper.getEventStats()),
  ]);
} catch (e) {
  channelStats = { totalChannels: 0, totalActive: 0, totalInactive: 0, totalCategories: 0, categories: [] };
  categories = [];
  allChannels = [];
  todayEvents = [];
  eventStats = { totalEvents: 0, uniqueCountries: [] };
}

function normalize(str) {
  return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
}

// Build a lookup from channel name to stream ID (case-insensitive, accent-insensitive)
const channelLookup = new Map();
for (const ch of allChannels) {
  const streamId = ch.streamUrl?.split('stream=')[1]?.split('&')[0];
  if (streamId) {
    channelLookup.set(normalize(ch.name), streamId);
  }
}

// Extract streamId from embed decoded params or match by name
function resolveStreamId(embed) {
  if (embed.iframe?.decodedParams?.stream) {
    return embed.iframe.decodedParams.stream;
  }
  if (embed.iframe?.decodedParams?.raw) {
    const raw = embed.iframe.decodedParams.raw;
    const match = raw.match(/stream=([^&\s]+)/);
    if (match) return match[1];
  }
  if (embed.name) {
    const normalized = normalize(embed.name);
    if (channelLookup.has(normalized)) return channelLookup.get(normalized);
    for (const [chName, streamId] of channelLookup) {
      if (chName.includes(normalized) || normalized.includes(chName)) {
        return streamId;
      }
    }
  }
  return null;
}

// Enrich today events with streamIds on embeds
for (const ev of todayEvents) {
  for (const embed of ev.embeds) {
    embed.streamId = resolveStreamId(embed);
  }
}

// Get active channels for featured grid
const featuredChannels = allChannels.filter(c => c.isActive).slice(0, 8);
