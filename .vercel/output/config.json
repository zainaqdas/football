{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/channels\\.json$",
			"dest": "_render"
		},
		{
			"src": "^/api/events\\.json$",
			"dest": "_render"
		},
		{
			"src": "^/api/hls-proxy/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/set-lang/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/stream-hls\\.json$",
			"dest": "_render"
		},
		{
			"src": "^/channels/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/channels/?$",
			"dest": "_render"
		},
		{
			"src": "^/events/?$",
			"dest": "_render"
		},
		{
			"src": "^/stream/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}